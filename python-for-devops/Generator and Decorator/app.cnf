# Global settings
timeout = 30
retry_count = 5

# Database configuration
[database]
host = db.prod.local
port = 5432
username = admin
password = secret123

# Redis configuration
[redis]
host = redis.prod.local
port = 6379
db = 0

# API service
[api_service]
url = https://api.service.com/v1?retries=3
timeout = 60
api_key = abc123xyz

# Logging configuration
[logging]
level = INFO
file = /var/log/app.log

# Email service
[email]
smtp_server = smtp.gmail.com
smtp_port = 587
sender = admin@example.com